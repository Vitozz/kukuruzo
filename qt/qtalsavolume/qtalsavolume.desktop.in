[Desktop Entry]
Encoding=UTF-8
Name=QtAlsaVolume
Icon=@PREFIX@/share/qtalsavolume/icons/@PROJECT_NAME@.png
Comment=Changes the volume of ALSA from the system tray
Exec=qtalsavolume
Terminal=false
Type=Application
Categories=Audio;AudioVideo;Mixer;Qt;
StartupNotify=false

Comment[ru]=Регулятор громкости ALSA
